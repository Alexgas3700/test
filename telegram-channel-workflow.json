{
  "name": "Telegram Channel Management",
  "nodes": [
    {
      "parameters": {},
      "id": "8b0d6c8f-3f3a-4e5e-8b3a-1c8f3e5e8b3a",
      "name": "When clicking 'Test workflow'",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
