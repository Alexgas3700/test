            {
              "value1": "={{ $json.messageType }}",
              "operation": "equals",
              "value2": "photo"
            }
          ]
        }
      },
      "id": "3m4n5o6p-7q8r-9s0t-1u2v-3w4x5y6z7a8b",
      "name": "Check Message Type",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [680, 700],
