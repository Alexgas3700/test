      "id": "1a2b3c4d-5e6f-7g8h-9i0j-1k2l3m4n5o6p",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [240, 500],
      "notesInFlow": true,
      "notes": "Запускается 3 раза в день: 9:00, 12:00, 18:00"
    },
    {
      "parameters": {
        "url": "https://api.rss2json.com/v1/api.json",
        "options": {
          "queryParameters": {
            "parameters": [
              {
                "name": "rss_url",
                "value": "={{ $json.feedUrl }}"
              },
              {
                "name": "api_key",
                "value": "={{ $credentials.rss2jsonApi }}"
              },
              {
                "name": "count",
                "value": "5"
              }
            ]
          }
        }
      },
      "id": "2b3c4d5e-6f7g-8h9i-0j1k-2l3m4n5o6p7q",
      "name": "Get RSS Feed",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [680, 500],
      "notesInFlow": true,
      "notes": "Получение контента из RSS-ленты"
    },
    {
      "parameters": {
        "content": "=## 📰 {{ $json.title }}\n\n{{ $json.description }}\n\n🔗 [Читать полностью]({{ $json.link }})\n\n#новости #telegram",
        "options": {}
      },
      "id": "3c4d5e6f-7g8h-9i0j-1k2l-3m4n5o6p7q8r",
      "name": "Format Message",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.2,
      "position": [900, 500],
      "notesInFlow": true,
      "notes": "Форматирование сообщения для Telegram"
    },
    {
      "parameters": {
        "chatId": "={{ $json.channelId }}",
        "text": "={{ $json.content }}",
        "additionalFields": {
          "parse_mode": "Markdown",
          "disable_web_page_preview": false
        }
      },
      "id": "4d5e6f7g-8h9i-0j1k-2l3m-4n5o6p7q8r9s",
      "name": "Send to Telegram",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [1120, 500],
      "credentials": {
        "telegramApi": {
          "id": "1",
          "name": "Telegram Bot API"
        }
      },
      "notesInFlow": true,
      "notes": "Отправка сообщения в канал"
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "feedUrl",
              "value": "https://example.com/rss"
            },
            {
              "name": "channelId",
              "value": "@your_channel_name"
            }
          ]
        },
        "options": {}
      },
      "id": "5e6f7g8h-9i0j-1k2l-3m4n-5o6p7q8r9s0t",
      "name": "Configuration",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.2,
      "position": [460, 500],
      "notesInFlow": true,
      "notes": "Настройки канала и источников"
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.status }}",
              "operation": "equals",
              "value2": "ok"
            }
          ]
        }
      },
      "id": "6f7g8h9i-0j1k-2l3m-4n5o-6p7q8r9s0t1u",
      "name": "Check Feed Status",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [900, 620],
      "notesInFlow": true,
      "notes": "Проверка успешности получения данных"
    },
    {
      "parameters": {
        "functionCode": "// Обработка и фильтрация новостей\nconst items = $input.all();\nconst processedItems = [];\n\nfor (const item of items) {\n  if (item.json.items && Array.isArray(item.json.items)) {\n    for (const article of item.json.items) {\n      // Проверка на дубликаты (можно добавить проверку в БД)\n      const publishDate = new Date(article.pubDate);\n      const now = new Date();\n      const hoursDiff = (now - publishDate) / (1000 * 60 * 60);\n      \n      // Публикуем только новости не старше 24 часов\n      if (hoursDiff <= 24) {\n        processedItems.push({\n          json: {\n            title: article.title,\n            description: article.description || article.content,\n            link: article.link,\n            pubDate: article.pubDate,\n            channelId: item.json.channelId || '@your_channel'\n          }\n        });\n      }\n    }\n  }\n}\n\nreturn processedItems;"
      },
      "id": "7g8h9i0j-1k2l-3m4n-5o6p-7q8r9s0t1u2v",
      "name": "Process Articles",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 380],
      "notesInFlow": true,
      "notes": "Обработка и фильтрация статей"
    },
    {
      "parameters": {
        "operation": "sendMessage",
        "chatId": "={{ $json.adminChatId }}",
        "text": "=❌ Ошибка при получении контента:\n{{ $json.error }}",
        "additionalFields": {}
      },
      "id": "8h9i0j1k-2l3m-4n5o-6p7q-8r9s0t1u2v3w",
      "name": "Error Notification",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [1120, 740],
      "credentials": {
        "telegramApi": {
          "id": "1",
          "name": "Telegram Bot API"
        }
      },
      "notesInFlow": true,
      "notes": "Уведомление об ошибках"
    },
    {
      "parameters": {
        "chatId": "={{ $json.channelId }}",
        "text": "=📢 Доброе утро! Сегодня {{ $now.format('DD.MM.YYYY') }}\n\n{{ $json.dailyMessage }}",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "id": "9i0j1k2l-3m4n-5o6p-7q8r-9s0t1u2v3w4x",
