      "parameters": {
        "mode": "webhook",
        "webhookId": "telegram-webhook"
      },
      "id": "1k2l3m4n-5o6p-7q8r-9s0t-1u2v3w4x5y6z",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [240, 700],
      "webhookId": "telegram-webhook",
      "notesInFlow": true,
      "notes": "Webhook для внешних интеграций"
    },
    {
      "parameters": {
        "functionCode": "// Обработка входящих webhook данных\nconst body = $input.first().json.body;\n\nreturn [{\n  json: {\n    message: body.message || body.text,\n    channelId: body.channelId || '@your_channel',\n    messageType: body.type || 'text',\n    scheduledTime: body.scheduledTime || null,\n    media: body.media || null\n  }\n}];"
      },
      "id": "2l3m4n5o-6p7q-8r9s-0t1u-2v3w4x5y6z7a",
      "name": "Process Webhook",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 700],
      "notesInFlow": true,
      "notes": "Обработка данных из webhook"
    },
    {
      "parameters": {
