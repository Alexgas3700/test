# VK API Configuration
# ID вашей группы VK (без знака минус)
# Пример: если URL группы https://vk.com/club123456789, то ID = 123456789
VK_GROUP_ID=123456789

# VK API Version (рекомендуется использовать последнюю стабильную версию)
VK_API_VERSION=5.131

# Content Source Configuration
# URL вашего API для получения постов
CONTENT_API_URL=https://your-api.com/posts

# API Authentication (если требуется)
CONTENT_API_KEY=your_api_key_here
CONTENT_API_TOKEN=your_api_token_here

# Schedule Configuration
# Интервал запуска workflow в часах (по умолчанию: 1)
SCHEDULE_INTERVAL_HOURS=1

# Logging Configuration
# Путь для сохранения логов (опционально)
LOG_FILE_PATH=/var/log/n8n/vk-automation.log

# Enable debug mode (true/false)
DEBUG_MODE=false

# Notification Settings (опционально)
# Email для уведомлений об ошибках
NOTIFICATION_EMAIL=admin@example.com

# Telegram Bot Token для уведомлений (опционально)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Retry Configuration
# Количество попыток повторной публикации при ошибке
MAX_RETRY_ATTEMPTS=3

# Задержка между попытками в секундах
RETRY_DELAY_SECONDS=5

# Image Processing
# Максимальный размер изображения в МБ
MAX_IMAGE_SIZE_MB=50

# Поддерживаемые форматы изображений (через запятую)
SUPPORTED_IMAGE_FORMATS=jpg,jpeg,png,gif

# Post Filtering
# Включить фильтрацию по типам постов (true/false)
ENABLE_POST_TYPE_FILTER=true

# Разрешенные типы постов (через запятую)
ALLOWED_POST_TYPES=text,image

# Rate Limiting
# Максимальное количество постов за один запуск
MAX_POSTS_PER_RUN=10

# Задержка между публикациями в секундах
DELAY_BETWEEN_POSTS=2

# Database Configuration (если используется база данных как источник)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=content_db
DB_USER=db_user
DB_PASSWORD=db_password

# Redis Configuration (для кэширования, опционально)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
