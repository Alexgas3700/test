# ==============================================
# Email Marketing Workflow - Configuration
# ==============================================

# -----------------
# REQUIRED SETTINGS
# -----------------

# SendGrid Configuration
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Website Configuration
WEBSITE_URL=https://yourdomain.com
DOMAIN=yourdomain.com

# Company Information
COMPANY_NAME=Your Company Name

# -----------------
# OPTIONAL SETTINGS
# -----------------

# Airtable Configuration (for campaign logging)
# Get your API key from: https://airtable.com/account
# Get Base ID from your Airtable base URL
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Slack Notifications (for reports and alerts)
# Create webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Analytics Webhook (for custom tracking)
WEBHOOK_URL=https://your-analytics-service.com

# Subscriber Data Source API
# Configure your CRM or database API endpoint
SUBSCRIBER_API_URL=https://your-crm-api.com/subscribers
SUBSCRIBER_API_KEY=your_api_key_here

# -----------------
# SMTP SETTINGS (Alternative to SendGrid)
# -----------------

# Uncomment and configure if using SMTP instead of SendGrid
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-specific-password
# SMTP_SECURE=true

# -----------------
# CAMPAIGN SETTINGS
# -----------------

# Segmentation Thresholds (in days)
NEW_LEAD_THRESHOLD=7
INACTIVE_THRESHOLD=30

# Special Offers
NEW_LEAD_DISCOUNT=20
REENGAGEMENT_DISCOUNT=30

# -----------------
# SCHEDULE SETTINGS
# -----------------

# Cron expression for campaign schedule
# Default: Every Monday at 9:00 AM
# CRON_SCHEDULE=0 9 * * 1

# -----------------
# ADVANCED SETTINGS
# -----------------

# Rate Limiting (emails per minute)
# RATE_LIMIT=60

# Batch Size (for processing large lists)
# BATCH_SIZE=100

# Retry Settings
# MAX_RETRIES=3
# RETRY_DELAY=5000

# Testing Mode (set to true to send test emails only)
# TEST_MODE=false
# TEST_EMAIL=your-test-email@example.com
