# N8N Customer Acquisition Email Campaign - Environment Variables
# Copy this file to your n8n instance Settings → Variables

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# URL of your entrepreneurs database API
# This endpoint should return a list of entrepreneur contacts
ENTREPRENEURS_DB_URL=https://your-database-api.com

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Email address that will appear as the sender
SENDER_EMAIL=marketing@yourcompany.com

# BCC email for analytics and tracking (optional)
# All sent emails will be BCC'd to this address
BCC_EMAIL=analytics@yourcompany.com

# =============================================================================
# LANDING PAGES AND LINKS
# =============================================================================

# Landing page where customers can claim their discount
# The discount code will be appended as a query parameter: ?code=XXXXX
LANDING_PAGE_URL=https://yourcompany.com/claim-offer

# Unsubscribe page URL
# The customer's email will be appended as a query parameter: ?email=xxx@example.com
UNSUBSCRIBE_URL=https://yourcompany.com/unsubscribe

# Privacy policy page URL
PRIVACY_URL=https://yourcompany.com/privacy

# =============================================================================
# CRM AND ANALYTICS
# =============================================================================

# CRM API URL for logging campaign activities
# This is used to track which emails were sent and when
CRM_API_URL=https://your-crm-api.com

# Error logging service URL
# Failed email attempts will be logged here for troubleshooting
ERROR_LOG_URL=https://your-logging-service.com

# =============================================================================
# SMTP CONFIGURATION (Configure in n8n Credentials Manager)
# =============================================================================

# These should be configured in n8n UI under Credentials → SMTP
# Do NOT store SMTP credentials in environment variables for security

# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# SMTP_SECURE=true

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Timezone for scheduling (default: Europe/Moscow)
# TZ=Europe/Moscow

# Maximum number of emails to send per batch (optional)
# MAX_BATCH_SIZE=100

# Delay between emails in milliseconds (optional, for rate limiting)
# EMAIL_DELAY_MS=1000

# =============================================================================
# TESTING AND DEVELOPMENT
# =============================================================================

# Set to 'true' to enable test mode (emails sent to TEST_EMAIL only)
# TEST_MODE=false

# Test email address for development
# TEST_EMAIL=test@yourcompany.com

# =============================================================================
# NOTES
# =============================================================================

# 1. Copy this file and configure all variables in n8n Settings → Variables
# 2. Never commit actual credentials to version control
# 3. Use n8n Credentials Manager for sensitive data like SMTP passwords
# 4. Ensure all URLs use HTTPS for security
# 5. Test the workflow with a small batch before full deployment
