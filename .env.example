# n8n Configuration
N8N_USER=admin
N8N_PASSWORD=changeme_strong_password
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
TIMEZONE=Europe/Moscow

# VK API Configuration
# Get your access token from: https://vk.com/apps?act=manage
# For group posting, use Service Access Token from group settings
VK_ACCESS_TOKEN=your_vk_access_token_here
# Group ID should be negative number (e.g., -123456789)
# Find it in your group URL: vk.com/club123456789 -> -123456789
VK_GROUP_ID=-123456789

# Google Sheets Configuration
# File ID from Google Sheets URL: 
# https://docs.google.com/spreadsheets/d/FILE_ID_HERE/edit
GOOGLE_SHEETS_FILE_ID=your_google_sheets_file_id_here
