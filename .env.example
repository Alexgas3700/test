# VK API Configuration
VK_ACCESS_TOKEN=your_vk_access_token_here
VK_OWNER_ID=-your_group_id_here
VK_API_VERSION=5.131

# n8n Configuration (if using environment variables)
N8N_ENCRYPTION_KEY=your_encryption_key_here

# Database Configuration (optional, for logging)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vk_workflow
DB_USER=postgres
DB_PASSWORD=your_password_here

# OpenAI Configuration (optional, for AI content generation)
OPENAI_API_KEY=your_openai_api_key_here

# Notification Configuration (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_password_here

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Workflow Settings
SCHEDULE_INTERVAL_HOURS=6
CONTENT_MAX_LENGTH=4096
ENABLE_LOGGING=true
ENABLE_NOTIFICATIONS=false
