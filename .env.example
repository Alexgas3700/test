# VK Content Workflow Configuration
# Скопируйте этот файл в .env и заполните своими значениями

# ============================================
# VK API Configuration
# ============================================

# VK Application ID
VK_APP_ID=your_app_id

# VK Application Secret
VK_APP_SECRET=your_app_secret

# VK Access Token (с правами wall, photos, video, groups)
VK_ACCESS_TOKEN=your_access_token

# VK Group ID (отрицательное значение для групп, например: -123456789)
VK_GROUP_ID=-123456789

# VK API Version
VK_API_VERSION=5.131

# ============================================
# n8n Configuration
# ============================================

# n8n Instance URL
N8N_HOST=https://your-n8n-instance.com

# n8n Webhook URL
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook

# n8n Basic Auth (если включена)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=secure_password

# ============================================
# Database Configuration (PostgreSQL)
# ============================================

# Database Host
DB_HOST=localhost

# Database Port
DB_PORT=5432

# Database Name
DB_NAME=vk_content

# Database User
DB_USER=postgres

# Database Password
DB_PASSWORD=your_db_password

# Database SSL Mode (disable, require, verify-ca, verify-full)
DB_SSL_MODE=disable

# Connection Pool Size
DB_POOL_SIZE=10

# ============================================
# OpenAI Configuration (для AI-генерации контента)
# ============================================

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key

# OpenAI Model
OPENAI_MODEL=gpt-4

# OpenAI Temperature (0.0 - 1.0)
OPENAI_TEMPERATURE=0.7

# OpenAI Max Tokens
OPENAI_MAX_TOKENS=500

# ============================================
# Notification Configuration
# ============================================

# Telegram Bot Token (для уведомлений)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Telegram Chat ID (для получения уведомлений)
TELEGRAM_CHAT_ID=your_chat_id

# Email Configuration (для уведомлений об ошибках)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=admin@example.com

# Slack Webhook URL (для уведомлений)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# Workflow Configuration
# ============================================

# Schedule Interval (в часах)
SCHEDULE_INTERVAL=2

# Max Posts Per Run
MAX_POSTS_PER_RUN=10

# Retry Attempts (количество попыток при ошибке)
RETRY_ATTEMPTS=3

# Retry Delay (задержка между попытками в секундах)
RETRY_DELAY=5

# ============================================
# Content Moderation
# ============================================

# Enable Content Moderation
ENABLE_MODERATION=true

# Banned Words (через запятую)
BANNED_WORDS=spam,scam,prohibited

# Min Message Length
MIN_MESSAGE_LENGTH=10

# Max Message Length
MAX_MESSAGE_LENGTH=16384

# Max Attachments
MAX_ATTACHMENTS=10

# ============================================
# Media Configuration
# ============================================

# Max Image Size (в байтах, 10MB по умолчанию)
MAX_IMAGE_SIZE=10485760

# Max Video Size (в байтах, 200MB по умолчанию)
MAX_VIDEO_SIZE=209715200

# Allowed Image Formats (через запятую)
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,gif,webp

# Allowed Video Formats (через запятую)
ALLOWED_VIDEO_FORMATS=mp4,avi,mov,wmv

# ============================================
# Caching Configuration
# ============================================

# Enable Caching
ENABLE_CACHE=true

# Cache TTL (в секундах)
CACHE_TTL=3600

# Redis Configuration (если используется)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# Logging Configuration
# ============================================

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# Log Format (json, text)
LOG_FORMAT=json

# Enable Database Logging
ENABLE_DB_LOGGING=true

# Enable File Logging
ENABLE_FILE_LOGGING=false

# Log File Path
LOG_FILE_PATH=/var/log/vk-content-workflow.log

# ============================================
# Security Configuration
# ============================================

# API Key for Webhook Authentication
WEBHOOK_API_KEY=your_secure_api_key

# Enable HTTPS Only
HTTPS_ONLY=true

# Enable Rate Limiting
ENABLE_RATE_LIMIT=true

# Rate Limit (requests per minute)
RATE_LIMIT=60

# ============================================
# Integration Configuration
# ============================================

# Google Sheets Configuration
GOOGLE_SHEETS_CLIENT_ID=your_client_id
GOOGLE_SHEETS_CLIENT_SECRET=your_client_secret
GOOGLE_SHEETS_REFRESH_TOKEN=your_refresh_token

# Airtable Configuration
AIRTABLE_API_KEY=your_airtable_api_key
AIRTABLE_BASE_ID=your_base_id

# Notion Configuration
NOTION_API_KEY=your_notion_api_key
NOTION_DATABASE_ID=your_database_id

# WordPress Configuration
WORDPRESS_URL=https://your-wordpress-site.com
WORDPRESS_USERNAME=your_username
WORDPRESS_PASSWORD=your_password

# Instagram Configuration
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_USER_ID=your_user_id

# ============================================
# Analytics Configuration
# ============================================

# Enable Analytics Collection
ENABLE_ANALYTICS=true

# Analytics Collection Interval (в часах)
ANALYTICS_INTERVAL=6

# Collect Detailed Stats
COLLECT_DETAILED_STATS=true

# ============================================
# Backup Configuration
# ============================================

# Enable Auto Backup
ENABLE_AUTO_BACKUP=true

# Backup Interval (в днях)
BACKUP_INTERVAL=7

# Backup Path
BACKUP_PATH=/backups

# Keep Backups (количество хранимых резервных копий)
KEEP_BACKUPS=4

# ============================================
# Development Configuration
# ============================================

# Environment (development, production)
NODE_ENV=production

# Debug Mode
DEBUG=false

# Test Mode (не публикует посты, только логирует)
TEST_MODE=false

# Dry Run (симулирует публикацию без реальной отправки)
DRY_RUN=false
