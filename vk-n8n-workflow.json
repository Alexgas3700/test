        "queryParameters": {
          "parameters": [
            {
              "name": "access_token",
              "value": "={{ $credentials.vkAccessToken }}"
            },
            {
              "name": "v",
              "value": "5.131"
            },
            {
              "name": "group_id",
              "value": "={{ Math.abs(parseInt($credentials.vkGroupId)) }}"
            }
          ]
        },
        "options": {}
      },
      "id": "vk-get-upload-server",
      "name": "VK Get Upload Server",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1350,
        300
      ],
      "credentials": {
        "httpQueryAuth": {
          "id": "2",
          "name": "VK API Credentials"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json.response.upload_url }}",
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            {
              "name": "photo",
              "inputDataFieldName": "={{ $binary.data }}"
            }
          ]
        },
        "options": {}
      },
      "id": "vk-upload-image",
      "name": "VK Upload Image",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1570,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.vk.com/method/photos.saveWallPhoto",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "access_token",
              "value": "={{ $credentials.vkAccessToken }}"
            },
            {
              "name": "v",
              "value": "5.131"
            },
            {
              "name": "group_id",
              "value": "={{ Math.abs(parseInt($credentials.vkGroupId)) }}"
            },
            {
              "name": "photo",
              "value": "={{ $json.photo }}"
            },
            {
              "name": "server",
              "value": "={{ $json.server }}"
            },
            {
              "name": "hash",
              "value": "={{ $json.hash }}"
            }
          ]
        },
        "options": {}
      },
      "id": "vk-save-photo",
      "name": "VK Save Photo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1790,
        300
      ],
      "credentials": {
        "httpQueryAuth": {
          "id": "2",
          "name": "VK API Credentials"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.vk.com/method/wall.post",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "access_token",
              "value": "={{ $credentials.vkAccessToken }}"
            },
            {
              "name": "v",
              "value": "5.131"
            },
            {
              "name": "owner_id",
              "value": "={{ $credentials.vkGroupId }}"
            },
            {
              "name": "message",
              "value": "={{ $node['Download Image'].json.content }}"
            },
            {
              "name": "attachments",
              "value": "={{ 'photo' + $json.response[0].owner_id + '_' + $json.response[0].id }}"
            },
            {
              "name": "from_group",
              "value": "1"
            }
          ]
        },
        "options": {}
      },
      "id": "vk-post-with-image",
      "name": "VK Post with Image",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2010,
        300
      ],
      "credentials": {
        "httpQueryAuth": {
          "id": "2",
          "name": "VK API Credentials"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.vk.com/method/polls.create",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "access_token",
              "value": "={{ $credentials.vkAccessToken }}"
            },
            {
              "name": "v",
              "value": "5.131"
            },
            {
              "name": "question",
              "value": "={{ $json.poll_question }}"
            },
            {
              "name": "add_answers",
              "value": "={{ JSON.stringify($json.poll_options.split('|')) }}"
            },
            {
              "name": "owner_id",
              "value": "={{ $credentials.vkGroupId }}"
            }
          ]
        },
        "options": {}
      },
      "id": "vk-create-poll",
      "name": "VK Create Poll",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1130,
        500
      ],
      "credentials": {
        "httpQueryAuth": {
          "id": "2",
