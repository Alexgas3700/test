      "parameters": {
        "method": "POST",
        "url": "https://api.vk.com/method/wall.post",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "access_token",
              "value": "={{ $credentials.vkAccessToken }}"
            },
            {
              "name": "v",
              "value": "5.131"
            },
            {
              "name": "owner_id",
              "value": "={{ $credentials.vkGroupId }}"
            },
            {
              "name": "message",
              "value": "={{ $node['If Poll Post'].json.content }}"
            },
            {
              "name": "attachments",
              "value": "={{ 'poll' + $json.response.owner_id + '_' + $json.response.id }}"
            },
            {
              "name": "from_group",
              "value": "1"
            }
          ]
        },
        "options": {}
      },
      "id": "vk-post-with-poll",
      "name": "VK Post with Poll",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1350,
        500
      ],
      "credentials": {
        "httpQueryAuth": {
          "id": "2",
          "name": "VK API Credentials"
        }
      }
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": {
          "__rl": true,
          "value": "={{ $node['Read Posts from Google Sheets'].json.fileId }}",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Sheet1",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "published": "true",
            "published_at": "={{ new Date().toISOString() }}"
          }
        },
        "options": {}
      },
      "id": "update-sheet-status",
      "name": "Update Sheet Status",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [
        2230,
        300
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "1",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "content": "## VK Auto Posting Workflow\n\nThis workflow automatically posts content to your VK group on a schedule.\n\n**Supported Content Types:**\n- Text posts\n- Image posts\n- Poll posts\n\n**Setup Required:**\n1. Configure VK API credentials\n2. Set up Google Sheets with post data\n3. Adjust schedule trigger as needed\n\n**Google Sheets Format:**\nColumns: post_date, post_type, content, image_url, poll_question, poll_options, published, published_at",
        "height": 464.79532953301575,
        "width": 389.0837696335078,
        "color": 4
      },
      "id": "sticky-note",
      "name": "Sticky Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        240,
        -80
      ]
    }
  ],
  "pinData": {},
