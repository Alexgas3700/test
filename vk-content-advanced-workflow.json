    {
      "parameters": {
        "jsCode": "// Content moderation and validation\nconst items = $input.all();\nconst results = [];\n\nconst bannedWords = ['spam', 'scam', 'prohibited'];\nconst maxLength = 16384;\nconst minLength = 10;\n\nfor (const item of items) {\n  const message = item.json.message || '';\n  const issues = [];\n  \n  // Check length\n  if (message.length < minLength) {\n    issues.push('Message too short');\n  }\n  if (message.length > maxLength) {\n    issues.push('Message too long');\n  }\n  \n  // Check for banned words\n  const lowerMessage = message.toLowerCase();\n  const foundBanned = bannedWords.filter(word => lowerMessage.includes(word));\n  if (foundBanned.length > 0) {\n    issues.push(`Contains banned words: ${foundBanned.join(', ')}`);\n  }\n  \n  // Check for required fields\n  if (!item.json.owner_id) {\n    issues.push('Missing owner_id');\n  }\n  \n  results.push({\n    json: {\n      ...item.json,\n      validation: {\n        passed: issues.length === 0,\n        issues: issues,\n        timestamp: new Date().toISOString()\n      }\n    },\n    pairedItem: item.pairedItem\n  });\n}\n\nreturn results;"
      },
      "id": "content-moderation",
      "name": "Content Moderation",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        500
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.validation.passed }}",
              "value2": true
            }
          ]
        }
      },
      "id": "check-validation",
      "name": "Check Validation",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        900,
        500
      ]
    },
    {
      "parameters": {
        "jsCode": "// Prepare VK post with all parameters\nconst items = $input.all();\nconst posts = [];\n\nfor (const item of items) {\n  const data = item.json;\n  \n  // Build attachments array\n  let attachments = [];\n  if (data.attachments && Array.isArray(data.attachments)) {\n    attachments = data.attachments;\n  }\n  \n  // Add uploaded photo if exists\n  if (data.uploaded_photo) {\n    attachments.push(data.uploaded_photo);\n  }\n  \n  // Format message with hashtags\n  let message = data.message || '';\n  if (data.hashtags && Array.isArray(data.hashtags)) {\n    const tags = data.hashtags.map(tag => {\n      return tag.startsWith('#') ? tag : `#${tag}`;\n    }).join(' ');\n    message += `\\n\\n${tags}`;\n  }\n  \n  // Add call-to-action if provided\n  if (data.cta_text && data.cta_link) {\n    message += `\\n\\n${data.cta_text}: ${data.cta_link}`;\n  }\n  \n  // Prepare post data\n  const postData = {\n    owner_id: data.owner_id,\n    message: message,\n    attachments: attachments.join(','),\n    from_group: data.from_group !== undefined ? data.from_group : 1,\n    services: data.services || null,\n    signed: data.signed || 0,\n    publish_date: data.publish_date ? Math.floor(new Date(data.publish_date).getTime() / 1000) : null,\n    lat: data.lat || null,\n    long: data.long || null,\n    place_id: data.place_id || null,\n    post_id: data.post_id || null,\n    guid: data.guid || `${Date.now()}_${Math.random().toString(36).substr(2, 9)}`,\n    mark_as_ads: data.mark_as_ads || 0,\n    close_comments: data.close_comments || 0,\n    donut_paid_duration: data.donut_paid_duration || null,\n    mute_notifications: data.mute_notifications || 0,\n    copyright: data.copyright || null\n  };\n  \n  // Add metadata for tracking\n  postData.metadata = {\n    created_at: new Date().toISOString(),\n    source: data.source || 'n8n_workflow',\n    campaign: data.campaign || null,\n    tags: data.tags || []\n  };\n  \n  posts.push({\n    json: postData,\n    pairedItem: item.pairedItem\n  });\n}\n\nreturn posts;"
      },
      "id": "prepare-post",
      "name": "Prepare Post",
