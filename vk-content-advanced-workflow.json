      "parameters": {
        "jsCode": "// Extract post ID and prepare analytics data\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const postId = item.json.post_id;\n  const ownerId = item.json.owner_id || item.json.from_id;\n  \n  results.push({\n    json: {\n      post_id: postId,\n      owner_id: ownerId,\n      full_id: `${ownerId}_${postId}`,\n      created_at: new Date().toISOString(),\n      message: item.json.text || '',\n      metadata: item.json.metadata || {},\n      vk_response: item.json\n    },\n    pairedItem: item.pairedItem\n  });\n}\n\nreturn results;"
      },
