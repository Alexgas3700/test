    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO vk_posts (post_id, owner_id, full_id, message, created_at, metadata, status)\nVALUES (\n  '{{ $json.post_id }}',\n  '{{ $json.owner_id }}',\n  '{{ $json.full_id }}',\n  '{{ $json.message }}',\n  '{{ $json.created_at }}',\n  '{{ JSON.stringify($json.metadata) }}',\n  'published'\n)\nON CONFLICT (full_id) DO UPDATE SET\n  message = EXCLUDED.message,\n  metadata = EXCLUDED.metadata,\n  updated_at = CURRENT_TIMESTAMP;",
        "options": {}
