      "id": "get-upload-server",
      "name": "Get Upload Server",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        680,
        500
      ],
      "disabled": true
    },
    {
      "parameters": {
        "jsCode": "// Validate content before posting\nconst message = $json.message;\nconst owner_id = $json.owner_id;\n\n// Validation rules\nconst errors = [];\n\nif (!message || message.trim().length === 0) {\n  errors.push(\"Message cannot be empty\");\n}\n\nif (message.length > 4096) {\n  errors.push(\"Message exceeds maximum length of 4096 characters\");\n}\n\nif (!owner_id) {\n  errors.push(\"Owner ID is required\");\n}\n\nif (errors.length > 0) {\n  return {\n    json: {\n      valid: false,\n      errors: errors,\n      original_data: $json\n    }\n  };\n}\n\nreturn {\n  json: {\n    valid: true,\n    ...($json)\n  }\n};"
      },
      "id": "validate-content",
      "name": "Validate Content",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "condition-1",
              "leftValue": "={{ $json.valid }}",
              "rightValue": "true",
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "check-validation",
      "name": "Check Validation",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        900,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Handle validation errors\nconst errors = $json.errors || [];\nconst errorMessage = errors.join(\", \");\n\nconsole.error(\"Validation failed:\", errorMessage);\n\nreturn {\n  json: {\n    status: \"validation_failed\",\n    errors: errors,\n    timestamp: new Date().toISOString()\n  }\n};"
      },
      "id": "handle-validation-error",
      "name": "Handle Validation Error",
      "type": "n8n-nodes-base.code",
