              "value": "1"
            }
          ]
        },
        "options": {}
      },
      "id": "vk-post-content",
      "name": "VK Post Content",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1060,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Generate content for VK post\nconst contentTemplates = [\n  \"🚀 Новый день - новые возможности! #мотивация #успех\",\n  \"💡 Совет дня: Начните с малого, но начните сегодня! #советы #развитие\",\n  \"🌟 Делитесь своими достижениями в комментариях! #сообщество #общение\",\n  \"📚 Узнайте что-то новое каждый день! #обучение #знания\",\n  \"🎯 Ставьте цели и достигайте их! #цели #мотивация\"\n];\n\nconst randomIndex = Math.floor(Math.random() * contentTemplates.length);\nconst message = contentTemplates[randomIndex];\n\n// You can customize these values\nconst owner_id = \"-YOUR_GROUP_ID\"; // Replace with your VK group ID (negative for groups)\nconst attachments = \"\"; // Add photo/video attachments if needed\n\nreturn {\n  json: {\n    owner_id: owner_id,\n    message: message,\n    attachments: attachments,\n    timestamp: new Date().toISOString()\n  }\n};"
      },
      "id": "generate-content",
      "name": "Generate Content",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "condition-1",
              "leftValue": "={{ $json.response?.error }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notExists"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
